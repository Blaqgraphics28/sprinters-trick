{
"compilerOptions": {
    "target": "es2016",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true, 
    "module": "commonjs", 
    "moduleResolution": "node",
    "baseUrl": "./",
    "resolveJsonModule": true, 
    "sourceMap": true, 
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true, 
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "outDir": "./dist"
  },
}
